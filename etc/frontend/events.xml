<?xml version="1.0"?>
<!--
/**
 * Panth Social Meta — Frontend events.
 *
 * Removes native Magento/Hyva OpenGraph blocks so duplicate og:* tags
 * never render alongside the module's own output.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="layout_generate_blocks_after">
        <observer name="panth_social_meta_remove_native_og"
                  instance="Panth\SocialMeta\Observer\Social\RemoveNativeOgObserver"/>
    </event>
</config>
